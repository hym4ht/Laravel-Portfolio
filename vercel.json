{
    "version": 2,
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.7.1",
            "includeFiles": "{app,config,database,public,resources,routes,vendor,bootstrap,storage/framework/views}/**",
            "excludeFiles": "{node_modules,tests,storage/logs,.git}/**"
        }
    },
    "routes": [
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "false",
        "APP_URL": "https://nama-proyek-kamu.vercel.app",
        "DB_CONNECTION": "libsql",
        "DB_URL": "@DB_URL",
        "DB_AUTH_TOKEN": "@DB_AUTH_TOKEN",
        "VIEW_COMPILED_PATH": "/tmp",
        "CACHE_DRIVER": "array",
        "SESSION_DRIVER": "cookie",
        "LOG_CHANNEL": "stderr"
    }
}